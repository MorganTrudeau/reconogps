    "@types/redux-logger": "^3.0.9",
    "babel-jest": "^29.6.3",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^6.5.1",
    "plist": "^3.1.0",
    "prettier": "2.8.8",
    "react-test-renderer": "19.0.0",
    "stripe": "^11.17.0",
    "typescript": "~5.8.3"
