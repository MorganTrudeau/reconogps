{
  "name": "recono",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "validate": "tsc --noEmit",
    "bump-version": "node scripts/bump_version",
    "bump-build-number": "BUILD_NUMBER=true node scripts/bump_version",
    "bundle:dev": "cd android && ENVFILE=.env.dev ./gradlew clean && ENVFILE=.env.dev ./gradlew bundleRelease",
    "bundle:live": "cd android && ENVFILE=.env.live ./gradlew clean && ENVFILE=.env.live ./gradlew bundleRelease",
    "android:dev": "ENVFILE=.env.dev npx react-native run-android --appId com.reconogps.dev.app",
    "android:live": "ENVFILE=.env.live npx react-native run-android"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@gorhom/portal": "^1.0.14",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-clipboard/clipboard": "^1.15.0",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-native-community/slider": "4.5.6",
    "@react-native-firebase/app": "21.14.0",
    "@react-native-firebase/functions": "21.14.0",
    "@react-native-firebase/messaging": "21.14.0",
    "@react-navigation/drawer": "^6.5.6",
    "@react-navigation/native": "^6.1.1",
    "@react-navigation/native-stack": "^6.9.7",
    "@reduxjs/toolkit": "^2.0.0",
    "@rnmapbox/maps": "10.3.0",
    "@stripe/stripe-react-native": "0.45.0",
    "axios": "^1.2.2",
    "expo": "53",
    "expo-image": "~2.4.1",
    "expo-image-manipulator": "~13.1.7",
    "expo-image-picker": "~16.1.4",
    "expo-location": "~18.1.6",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "moment": "^2.29.4",
    "query-string": "^8.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-config": "^1.5.5",
    "react-native-dotenv": "^3.4.7",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
